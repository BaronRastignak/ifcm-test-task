<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:IncomingFileDetector.ViewModel"
        xmlns:model="clr-namespace:IncomingFileDetector.Service.Model;assembly=IncomingFileDetector.Service"
        xmlns:convert="clr-namespace:IncomingFileDetector.Converters"
        mc:Ignorable="d"
        x:Class="IncomingFileDetector.MainWindow"
        Title="Incoming File Detector" Height="450" Width="800" ShowActivated="False"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">
    <Window.Resources>
        <convert:UtcToLocalTimeZoneFormatter x:Key="UtcToLocalTimeZoneFormatter" />
    </Window.Resources>

    <StackPanel>
        <Grid Margin="5,5,5,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Label x:Name="LabelObservedDirectory" Content="{Binding ObservedDirectory}" ContentStringFormat="Scanning directory: {0}" HorizontalAlignment="Left"/>
            <Button Grid.Column="1" x:Name="ButtonChangeDirectory" Content="..." HorizontalAlignment="Right" Width="24" ToolTip="Change the directory to scan" Click="ButtonChangeDirectoryOnClick"/>
        </Grid>

        <Grid Margin="5,5,5,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>

            <Label Content="Directory polling timeout, seconds:" />
            <Slider x:Name="SliderPollingTimeout" Grid.Column="1" Margin="20,0,0,0" Minimum="1" Maximum="60" LargeChange="5" SmallChange="1" TickFrequency="5" TickPlacement="BottomRight" AutoToolTipPlacement="TopLeft" Value="{Binding PollingTimeout}"/>
            <Label Grid.Column="2" Content="{Binding PollingTimeout}" HorizontalAlignment="Center" />

        </Grid>

        <ListView x:Name="ListRegisteredFiles" d:DataContext="{d:DesignInstance model:IncomingFile}">
            <ListView.View>
                <GridView>
                    <GridViewColumn DisplayMemberBinding="{
                        Binding Path=RegisteredAt,
                        Converter={StaticResource UtcToLocalTimeZoneFormatter},
                        StringFormat='G'}" Header="Registered At" />

                    <GridViewColumn DisplayMemberBinding="{Binding Path=FileName}" Header="File Name" />

                    <GridViewColumn DisplayMemberBinding="{Binding Path=MimeType}" Header="MIME Type" />
                </GridView>
            </ListView.View>
        </ListView>
        

    </StackPanel>
</Window>
