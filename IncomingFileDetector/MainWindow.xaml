<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:model="clr-namespace:IncomingFileDetector.Service.Model;assembly=IncomingFileDetector.Service"
        mc:Ignorable="d"
        x:Class="IncomingFileDetector.MainWindow"
        Title="Incoming File Detector" Height="450" Width="800" ShowActivated="False"
        d:DataContext="{d:DesignInstance model:IncomingFile}">
    <StackPanel>
        <ListView x:Name="ListRegisteredFiles">
            <ListView.View>
                <GridView>
                    <GridViewColumn DisplayMemberBinding="{Binding Path=RegisteredAt}" Header="Registered At"/>

                    <GridViewColumn DisplayMemberBinding="{Binding Path=FileName}" Header="File Name" />

                    <GridViewColumn DisplayMemberBinding="{Binding Path=MimeType}" Header="MIME Type" />
                </GridView>
            </ListView.View>
        </ListView>

    </StackPanel>
</Window>
